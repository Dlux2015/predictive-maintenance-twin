          ["PredictiveMaintenance", "BronzeWriteLatencyMs", {"stat": "p99", "period": 300, "color": "#8b4513", "label": "p99 Bronze Latency"}]
        ],
        "period": 300,
        "region": "us-east-1",
        "yAxis": {"left": {"min": 0, "label": "Milliseconds"}},
        "legend": {"position": "bottom"}
      }
    },

