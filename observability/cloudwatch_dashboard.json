{
  "start": "-PT3H",
  "periodOverride": "inherit",
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Predictive Maintenance Digital Twin — Pipeline Health Dashboard\nNamespace: `PredictiveMaintenance` | Stream: `pmt-sensor-stream` | Bucket: `predictive-maintenance-twin-raw`"
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Records Ingested (5-min sum)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["PredictiveMaintenance", "RecordsIngested", {"stat": "Sum", "period": 300, "label": "Records Ingested"}]
        ],
        "period": 300,
        "stat": "Sum",
        "region": "us-east-1",
        "annotations": {
          "horizontal": [
            {"color": "#ff6961", "label": "Stale threshold", "value": 1, "fill": "below"}
          ]
        },
        "yAxis": {"left": {"min": 0, "label": "Records"}},
        "legend": {"position": "bottom"}
      }
    },

    {
      "type": "metric",
      "x": 8,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Pipeline Errors (5-min sum)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["PredictiveMaintenance", "PipelineErrors", {"stat": "Sum", "period": 300, "color": "#d62728", "label": "Pipeline Errors"}]
        ],
        "period": 300,
        "stat": "Sum",
        "region": "us-east-1",
        "annotations": {
          "horizontal": [
            {"color": "#ff6961", "label": "Alert threshold", "value": 1, "fill": "above"}
          ]
        },
        "yAxis": {"left": {"min": 0, "label": "Errors"}},
        "legend": {"position": "bottom"}
      }
    },

    {
      "type": "metric",
      "x": 16,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Kinesis Iterator Age (ms)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          ["AWS/Kinesis", "GetRecords.IteratorAgeMilliseconds", "StreamName", "pmt-sensor-stream", {"stat": "Maximum", "period": 300, "color": "#ff7f0e", "label": "Max Iterator Age"}]
        ],
        "period": 300,
        "stat": "Maximum",
        "region": "us-east-1",
        "annotations": {
          "horizontal": [
            {"color": "#ff6961", "label": "Lag alarm threshold (60s)", "value": 60000, "fill": "above"}
          ]
        },
        "yAxis": {"left": {"min": 0, "label": "Milliseconds"}},
        "legend": {"position": "bottom"}
      }
    },

    {
      "type": "metric",
      "x": 0,
      "y": 7,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Bronze Write Latency (ms)",
